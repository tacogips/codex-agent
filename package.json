{
  "name": "codex-agent",
  "version": "0.1.0",
  "description": "a",
  "type": "module",
  "main": "dist/main.js",
  "module": "dist/main.js",
  "types": "dist/main.d.ts",
  "bin": {
    "codex-agent": "./dist/bin.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js",
      "default": "./dist/main.js"
    },
    "./sdk": {
      "types": "./dist/sdk/index.d.ts",
      "import": "./dist/sdk/index.js",
      "default": "./dist/sdk/index.js"
    },
    "./sdk/testing": {
      "types": "./dist/sdk/mock-session-runner.d.ts",
      "import": "./dist/sdk/mock-session-runner.js",
      "default": "./dist/sdk/mock-session-runner.js"
    }
  },
  "scripts": {
    "dev": "bun run --watch src/main.ts",
    "build": "rm -rf dist && tsc -p tsconfig.build.json && bun build src/main.ts src/bin.ts src/sdk/index.ts src/sdk/mock-session-runner.ts --outdir dist --target bun",
    "prepack": "bun run build",
    "start": "bun run src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "bun run lint:biome && bun run typecheck",
    "lint:biome": "scripts/biome.sh check . --diagnostic-level=warn",
    "check:dist-sync": "bun run scripts/check-dist-sync.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "clean": "rm -rf dist"
  },
  "homepage": "https://github.com/user/repo",
  "repository": {
    "type": "git",
    "url": "https://github.com/user/repo"
  },
  "license": "MIT",
  "trustedDependencies": [],
  "devDependencies": {
    "@types/bun": "1.1.14",
    "prettier": "3.4.2",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  },
  "dependencies": {
    "graphql": "16.13.1"
  }
}
